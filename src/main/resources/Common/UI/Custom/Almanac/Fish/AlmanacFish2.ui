$Common = "Common.ui";

@Background = PatchStyle(TexturePath: "../book_2.png");
@FishTexture = PatchStyle(TexturePath: "Fish1.png");
@Fish2Texture = PatchStyle(TexturePath: "Fish2.png");
@Fish1Stamp = PatchStyle(TexturePath: "Stamps/Fish1_stamp.png");
@Fish2Stamp = PatchStyle(TexturePath: "Stamps/Fish2_stamp.png");

Group #AlmanacStats {
  Anchor: (Width: 1200, Height: 872);

  Group #background {
    Background: @Background;
  }

  Group #BookNav
  {
    // NAV BUTTONS
    Button  #PrevPageButton {
      Anchor: (Bottom: 45, Left: 115, Width: 60, Height: 30);
      Background: #3A3A3A;
    }

    Button  #NextPageButton {
      Anchor: (Bottom: 45, Right: 65, Width: 60, Height: 30);
      Background: #3A3A3A;
    }
  }

  // LEFT PAGE
  Group #LeftPage {
    Anchor: (Left: 100, Top: 60, Width: 450, Height: 750);

    Label #Header {
      Anchor: (Top: 10, Left:20);
      Style: (TextColor: #2A2A2A, FontSize: 38, RenderBold: true);
      Text: "{Fish name}";
    }

    Group #FishContainer {
      Anchor: (Top: 70, Left:30, Width: 250, Height: 250);
      AssetImage #FishImage {}
    }

    Group #QuickStatsRow {
      Anchor: (Top: 300, Left: 40, Width: 500, Height: 60);

      Label #FamilyLabel {
        Anchor: (Top: 0, Left: 310);
        Style: (TextColor: #7A6652, FontSize: 18, RenderBold: true);
        Text: "Species:";
      }
      Label #Family {
        Anchor: (Top: 20, Left: 320);
        Style: (TextColor: #3A3A3A, FontSize: 18);
        Text: "{Fish familly}";
      }

      Label #CountLabel {
        Anchor: (Top: 0, Left: 30);
        Style: (TextColor: #7A6652, FontSize: 20, RenderBold: true);
        Text: "Total caught:";
      }
      Label #CountNumber {
        Anchor: (Top:0, Left: 160);
        Style: (TextColor: #2A5A82, FontSize: 20);
        Text: "{total_catches}";
      }
    }

    Label #Description {
      Anchor: (Top: 360, Left: 40, Width: 380);
      Style: (TextColor: #494950, FontSize: 20, Wrap: true);
      Text: "{Fish_info}";
    }

    Group #HabitatSection {
      Anchor: (Top: 10, Left: 275, Width: 300);
      Label #HabitatTitle {
        Style: (TextColor: #2A5A82, FontSize: 18, RenderBold: true);
        Text: "Habitat:";
      }
      Label #HabitatList {
        Anchor: (Top:0, Left: 75);
        Style: (TextColor: #494950, FontSize: 18);
        Text: "{Fish_Habitat}";
      }
    }

    Group #Stamp {
      Anchor: (Bottom: 20, Right: 20, Width: 140, Height: 140);
      AssetImage #StampImage {}
    }
  }

  // RIGHT PAGE
  Group #RightPage {
    Anchor: (Right: 120, Top: 60, Width: 450, Height: 750);

    Label #Header2 {
      Anchor: (Top: 10, Left:20);
      Style: (TextColor: #2A2A2A, FontSize: 38, RenderBold: true);
      Text: "{Fish2 name}";
    }

    Group #FishContainer2 {
      Anchor: (Top: 70, Left:30, Width: 250, Height: 250);
      AssetImage #FishImage2 {}
    }

    Group #StatsBox2 {
      Anchor: (Top: 300, Left: 40, Width: 500, Height: 60);
      Label #FamilyLabel2 {
        Anchor: (Top: 0, Left: 310);
        Style: (TextColor: #7A6652, FontSize: 18, RenderBold: true);
        Text: "Species:";
      }
      Label #Family2 {
        Anchor: (Top: 20, Left: 320);
        Style: (TextColor: #3A3A3A, FontSize: 18);
        Text: "{Fish familly}";
      }

      Label #CountLabel2 {
        Anchor: (Top: 0, Left: 30);
        Style: (TextColor: #7A6652, FontSize: 20, RenderBold: true);
        Text: "Total caught:";
      }
      Label #CountNumber2 {
        Anchor: (Top:0, Left: 160);
        Style: (TextColor: #2A5A82, FontSize: 20);
        Text: "{total_catches}";
      }
    }

    Label #Description2 {
      Anchor: (Top: 360, Left: 40, Width: 380);
      Style: (TextColor: #494950, FontSize: 20, Wrap: true);
      Text: "{Fish2_info}";
    }

    Group #HabitatSection2 {
      Anchor: (Top: 10, Left: 275, Width: 300);
      Label #HabitatTitle2 {
        Style: (TextColor: #2A5A82, FontSize: 18, RenderBold: true);
        Text: "Habitat:";
      }
      Label #HabitatList2 {
        Anchor: (Top:0, Left: 75);
        Style: (TextColor: #494950, FontSize: 18);
        Text: "{Fish_Habitat}";
      }
    }

    Group #Stamp2 {
      Anchor: (Bottom: 20, Right: 20, Width: 150, Height: 150);
      AssetImage #StampImage2 {}
    }
  }
}
Group #FPageContent {
  Anchor: (Width: 450, Height: 750);

  Label #Header {
    Anchor: (Top: 10, Left: 20);
    Style: (TextColor: #2A2A2A, FontSize: 38, RenderBold: true);
    Text: "{Fish name}";
  }

  Group #HabitatSection {
    Anchor: (Top: 10, Left: 275, Width: 200);
    Label #HabitatTitle {
      Style: (TextColor: #2A5A82, FontSize: 18, RenderBold: true);
      Text: "Habitat:";
    }
    Label #HabitatList {
      Anchor: (Top: 0, Left: 75);
      Style: (TextColor: #494950, FontSize: 18);
      Text: "{Fish_Habitat}";
    }
  }

  Group #FishContainer {
    Anchor: (Top: 70, Left: 30, Width: 250, Height: 250);
    AssetImage #FishImage {
    }
  }

  Group #QuickStatsRow {
    Anchor: (Top: 300, Left: 40, Width: 400, Height: 60);

    Label #CountLabel {
      Anchor: (Top: 0, Left: 0);
      Style: (TextColor: #7A6652, FontSize: 20, RenderBold: true);
      Text: "Total caught:";
    }
    Label #CountNumber {
      Anchor: (Top: 0, Left: 140);
      Style: (TextColor: #2A5A82, FontSize: 20);
      Text: "{total_catches}";
    }

    Label #FamilyLabel {
      Anchor: (Top: 0, Left: 260);
      Style: (TextColor: #7A6652, FontSize: 18, RenderBold: true);
      Text: "Species:";
    }
    Label #Family {
      Anchor: (Top: 20, Left: 270);
      Style: (TextColor: #3A3A3A, FontSize: 18);
      Text: "{Fish familly}";
    }
  }

  Label #Description {
    Anchor: (Top: 360, Left: 40, Width: 380);
    Style: (TextColor: #494950, FontSize: 20, Wrap: true);
    Text: "{Fish_info}";
  }

  Group #Stamp {
    Anchor: (Bottom: 20, Right: 20, Width: 140, Height: 140);
    AssetImage #StampImage {
    }
  }
}
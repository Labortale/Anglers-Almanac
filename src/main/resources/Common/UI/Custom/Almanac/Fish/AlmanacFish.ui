$Common = "Common.ui";

@Background = PatchStyle(TexturePath: "../book_2.png");
@FishTexture = PatchStyle(TexturePath: "Fish1.png");
@Fish2Texture = PatchStyle(TexturePath: "Fish2.png");
@Fish1Stamp = PatchStyle(TexturePath: "Stamps/Fish1_stamp.png");
@Fish2Stamp = PatchStyle(TexturePath: "Stamps/Fish2_stamp.png");

Group #AlmanacStats {
  Anchor: (Width: 1200, Height: 872);
  Group #background {
    Background: @Background;
  }

  Group #BookNav
  {
    // NAV BUTTONS
    Button  #PrevPageButton {
      Anchor: (Bottom: 45, Left: 115, Width: 60, Height: 30);
      Background: #3A3A3A;
    }

    Button  #NextPageButton {
      Anchor: (Bottom: 45, Right: 65, Width: 60, Height: 30);
      Background: #3A3A3A;
    }
  }

  // LEFT PAGE
  Group #LeftPage {
    Anchor: (Left: 100, Top: 60, Width: 450, Height: 750);

    Label #Header {
      Anchor: (Top: 0, Left: 50);
      Style: (TextColor: #3A3A3A, FontSize: 32, RenderBold: true);
      Text: "{Fish name}";
    }

    Group #CounterSection {
      Anchor: (Top: 45, Left: 50, Width: 380, Height: 30);
      Label #CountLabel { 
        Style: (TextColor: #7A6652, FontSize: 18, RenderBold: true); 
        Text: "Total caught:"; 
        }
      Label #CountNumber { 
        Anchor: (Left: 115); 
        Style: (TextColor: #3A3A3A, FontSize: 18); 
        Text: "{total_catches}"; 
      }
    }

    Group #FishContainer {
      Anchor: (Top: 100, Left: 50, Width: 250, Height: 250);
      AssetImage #FishImage {}
    }

    Group #QuickStats {
      Anchor: (Top: 130, Left: 310, Width: 160);
      Label #FamilyLabel { 
        Style: (TextColor: #7A6652, FontSize: 14, RenderBold: true); 
        Text: "Species Class:"; 
      }

      Label #Family { 
        Anchor: (Top: 20); 
        Style: (TextColor: #5A4D41, FontSize: 20, Wrap: true); 
        Text: "{Fish familly}";
      }
    }

    Label #Description {
      Anchor: (Top: 350, Left: 40, Width: 400, Height: 200);
      Style: (TextColor: #494950, FontSize: 19, Wrap: true);
      Text: "{Fish_info}";
    }

    Group #HabitatSection {
      Anchor: (Top: 540, Left: 40, Width: 380);
      Label #HabitatTitle { 
        Style: (TextColor: #2A5A82, FontSize: 18, RenderBold: true); 
        Text: "LURKS WITHIN:"; 
      }

      Label #HabitatList { 
        Anchor: (Top: 25); 
        Style: (TextColor: #494950, FontSize: 17); 
        Text: "{Fish_Habitat}"; 
      }
    }

    Group #Stamp {
      Anchor: (Bottom: 50, Right: 0, Width: 180, Height: 180);
      AssetImage #StampImage {}
    }
  }

  // RIGHT PAGE
  Group #RightPage {
    Anchor: (Right: 120, Top: 60, Width: 450, Height: 750);

    Label #Header2 {
      Anchor: (Top: 0, Left: 50);
      Style: (TextColor: #3A3A3A, FontSize: 32, RenderBold: true);
      Text: "{Fish2 name}";
    }
  
    Group #CounterSection2 {
      Anchor: (Top: 45, Left: 50, Width: 380, Height: 30);
      Label #CountLabel2 { 
        Style: (TextColor: #7A6652, FontSize: 18, RenderBold: true); 
        Text: "Total caught:"; 
      }

      Label #CountNumber2 { 
        Anchor: (Left: 115); 
        Style: (TextColor: #3A3A3A, FontSize: 18); 
        Text: "{total_catches2}"; 
      }
    }
  
    Group #FishContainer2 {
      Anchor: (Top: 100, Left: 50, Width: 250, Height: 250);
      AssetImage #FishImage2 {}
    }
  
    Group #QuickStats2 {
      Anchor: (Top: 130, Left: 310, Width: 160);
      Label #FamilyLabel2 { 
        Style: (TextColor: #7A6652, FontSize: 14, RenderBold: true); 
        Text: "Species Class:"; 
      
      }
      Label #Family2 { 
        Anchor: (Top: 20); 
        Style: (TextColor: #5A4D41, FontSize: 20, Wrap: true); 
        Text: "{Fish2 familly}"; 
      }
    }
  
    Label #Description2 {
      Anchor: (Top: 340, Left: 40, Width: 400, Height: 200);
      Style: (TextColor: #494950, FontSize: 19, Wrap: true);
      Text: "{Fish2_info}";
    }
  
    Group #HabitatSection2 {
      Anchor: (Top: 540, Left: 40, Width: 380);
      Label #HabitatTitle2 { 
        Style: (TextColor: #2A5A82, FontSize: 18, RenderBold: true); 
        Text: "LURKS WITHIN:"; 
      }
      Label #HabitatList2 { 
        Anchor: (Top: 25); 
        Style: (TextColor: #494950, FontSize: 17); 
        Text: "{Fish_Habitat}"; 
      }
    }
  
    Group #Stamp2 {
      Anchor: (Bottom: 50, Right: 0, Width: 180, Height: 180);
      AssetImage #StampImage2 {}
    }
  }
}